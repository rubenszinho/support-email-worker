# Default support email used as a fallback when an Origin isn't in DOMAIN_CONFIG
# (local dev, curl tests, unknown referrers). Per-domain overrides live in DOMAIN_CONFIG.
SUPPORT_EMAIL=support@example.com

# Default display name for auto-reply emails when no per-domain fromName is set.
FROM_NAME=Support Team

# (Optional) Slack Webhook URL. Leave empty to skip Slack notifications entirely.
# Get this from: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Recipients that contact-form submissions are forwarded to (via Cloudflare
# `send_email` binding). Comma-separated. Each address must be a verified
# destination in Cloudflare Email Routing AND listed in wrangler.jsonc under
# `send_email[0].allowed_destination_addresses`.
FORWARD_EMAIL_LIST=samuelrubenscontato@gmail.com

# Extra CORS origins. Origins from DOMAIN_CONFIG are already allowed (with apex + www
# variants); use this only for preview URLs, staging, or other extras. Comma-separated.
ALLOWED_ORIGINS=

# Cloudflare Turnstile secret key (paired with VITE_TURNSTILE_SITE_KEY on each frontend).
# Get this from: https://dash.cloudflare.com/?to=/:account/turnstile
# In production, set via `wrangler secret put TURNSTILE_SECRET_KEY`.
TURNSTILE_SECRET_KEY=

# Resend API key (https://resend.com). Used by services/resend.js to send the
# auto-reply to the form submitter. Free plan = 3000 emails/mo, ONE verified
# sender domain. In production, set via `wrangler secret put RESEND_API_KEY`.
RESEND_API_KEY=

# Resend verified sender address. All portals reply from this single address
# (free plan limitation — one domain). Display name still varies per site via
# DOMAIN_CONFIG.fromName.
RESEND_FROM_EMAIL=hello@rubrion.ai

# Multi-tenant per-domain config. JSON-encoded string keyed by bare hostname.
# www.<host> is matched against the bare entry automatically. Each entry sets
# the from-address (used by the forward path's send_email binding) and display
# name (used by both forward and Resend auto-reply).
DOMAIN_CONFIG={"rubrion.ai":{"supportEmail":"hello@rubrion.ai","fromName":"Rubrion"},"rubrion.com.br":{"supportEmail":"ola@rubrion.com.br","fromName":"Rubrion BR"},"rubenszinho.dev":{"supportEmail":"contact@rubenszinho.dev","fromName":"Samuel Rubens"},"samuelrubens.com":{"supportEmail":"contato@samuelrubens.com","fromName":"Samuel Rubens"}}
